+ * @param dest_call_id  The call id to be replaced.
+ * @param options       See #pjsua_call_xfer_replaces().
+ * @param msg_data      Optional message components to be sent with the request.
+ *
+ * @return              PJ_SUCCESS on success, or the appropriate error code.
+ */
+PJ_DECL(pj_status_t) pjsua_call_xfer_replaces_contact(pjsua_call_id call_id,
+                                                       pjsua_call_id dest_call_id,
